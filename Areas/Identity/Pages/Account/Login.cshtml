@page
@model LoginModel
@{
    Layout = null; // important for full custom layout
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            height: 100vh;
            font-family: 'Segoe UI', sans-serif;
        }

        .container-custom {
            display: flex;
            height: 100vh;
        }

        /* LEFT SIDE */
        .left-panel {
            width: 50%;
            background: #1f3a5f;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 80px;
        }

            .left-panel h1 {
                font-size: 40px;
                font-weight: 700;
            }

            .left-panel p {
                margin-top: 20px;
                color: #cbd5e1;
            }

        /* RIGHT SIDE */
        .right-panel {
            width: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f8fafc;
        }

        .login-box {
            width: 350px;
        }

            .login-box h2 {
                font-weight: 600;
                margin-bottom: 10px;
            }

        .form-control {
            height: 45px;
        }

        .btn-login {
            background-color: #22c55e;
            border: none;
            height: 45px;
            font-weight: 600;
        }

            .btn-login:hover {
                background-color: #16a34a;
            }

        .social-btns button {
            width: 48%;
        }
    </style>
</head>
<body>

    <div class="container-custom">

        <!-- LEFT SIDE -->
        <div class="left-panel">
            <h3>WorkFlow</h3>

            <h1>Welcome back to your workspace</h1>

            <p>
                Manage projects, collaborate with teams,
                and grow your business — all in one place.
            </p>
        </div>

        <!-- RIGHT SIDE -->
        <div class="right-panel">
            <div class="login-box">

                <h2>Sign in to your account</h2>
                <p class="text-muted">Enter your credentials to access your dashboard</p>

                <form method="post">

                    <div class="mb-3">
                        <label>Email Address</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" />
                    </div>

                    <div class="mb-2">
                        <label>Password</label>
                        <input asp-for="Input.Password" type="password" class="form-control" />
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <div>
                            <input asp-for="Input.RememberMe" />
                            <label>Remember me</label>
                        </div>
                        <a asp-page="./ForgotPassword">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn btn-login w-100 mb-3">
                        Sign In →
                    </button>

                    <div class="text-center mb-2">OR CONTINUE WITH</div>

                    <div class="d-flex justify-content-between social-btns">
                        <button type="button" class="btn btn-outline-secondary">Google</button>
                        <button type="button" class="btn btn-outline-secondary">GitHub</button>
                    </div>

                    <p class="text-center mt-3">
                        Don't have an account?
                        <a asp-page="./Register">Sign up free</a>
                    </p>

                </form>

            </div>
        </div>

    </div>

</body>
</html>
