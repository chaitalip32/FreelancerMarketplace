@page
@model LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - WorkFlow</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        :root {
            --deep-navy: #1e293b;
            --emerald: #22c55e;
            --emerald-hover: #16a34a;
            --border-color: #e5e7eb;
            --text-muted: #6b7280;
            --bg-right: #f1f5f9; /* The exact light gray background from Lovable */
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Inter', -apple-system, sans-serif;
        }

        .container-custom {
            display: flex;
            min-height: 100vh;
        }

        /* LEFT PANEL */
        .left-panel {
            width: 50%;
            background-color: #1a2233;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 80px;
        }

        .logo-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 32px;
        }

        .logo-box {
            background-color: var(--emerald);
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .left-panel h1 {
            font-size: 44px;
            font-weight: 700;
            line-height: 1.1;
            margin-bottom: 20px;
        }

        .left-panel p {
            color: #9ca3af;
            font-size: 18px;
            line-height: 1.6;
            max-width: 400px;
        }

        /* RIGHT PANEL - NO CARD, FLAT DESIGN */
        .right-panel {
            width: 50%;
            background-color: #f8fafc; /* Very light slate background */
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
        }

        .login-content {
            width: 100%;
            max-width: 400px;
        }

        /* MOBILE LOGO */
        .mobile-logo {
            display: none;
            margin-bottom: 40px;
        }

        .login-content h2 {
            font-size: 28px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 8px;
        }

        .login-content p.subtitle {
            color: var(--text-muted);
            margin-bottom: 32px;
        }

        .form-label {
            font-size: 14px;
            font-weight: 500;
            color: #334155;
            margin-bottom: 8px;
        }

        .input-group {
            margin-bottom: 20px;
        }

        .form-control {
            height: 48px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background-color: white;
            padding-left: 12px;
        }

        .input-group-text {
            background-color: white;
            border-right: none;
            color: #94a3b8;
        }

        .form-control:focus {
            border-color: var(--emerald);
            box-shadow: none;
        }

        /* REMEMBER ME SECTION */
        /* Precise alignment for the checkbox row */
        .remember-row {
            margin-bottom: 24px;
            display: flex;
            align-items: center; /* Vertically centers checkbox with text */
            gap: 8px; /* Exact spacing from the design */
            font-size: 14px;
            color: var(--text-muted);
            cursor: pointer;
        }

        /* Fix for Bootstrap's default checkbox margin */
        .form-check-input {
            margin-top: 0; /* Removes Bootstrap's default top offset */
            cursor: pointer;
            width: 16px;
            height: 16px;
            border: 1px solid #d1d5db;
        }

            .form-check-input:checked {
                background-color: var(--emerald);
                border-color: var(--emerald);
            }

        /* BUTTONS */
        .btn-login {
            background-color: var(--emerald);
            color: white;
            border: none;
            height: 48px;
            font-weight: 600;
            border-radius: 8px;
            margin-bottom: 24px;
            transition: 0.2s;
        }

            .btn-login:hover {
                background-color: var(--emerald-hover);
            }

        .divider {
            display: flex;
            align-items: center;
            font-size: 11px;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 24px;
        }

            .divider::before, .divider::after {
                content: "";
                flex: 1;
                height: 1px;
                background: #e2e8f0;
            }

            .divider:not(:empty)::before {
                margin-right: 12px;
            }

            .divider:not(:empty)::after {
                margin-left: 12px;
            }

        .btn-social {
            background-color: white;
            border: 1px solid #e2e8f0;
            height: 48px;
            border-radius: 8px;
            font-weight: 500;
            color: #334155;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .btn-social:hover {
                background-color: #f8fafc;
                border-color: #cbd5e1;
            }

        .signup-text {
            text-align: center;
            font-size: 14px;
            color: var(--text-muted);
            margin-top: 32px;
        }

            .signup-text a {
                color: var(--emerald);
                text-decoration: none;
                font-weight: 600;
            }

        /* RESPONSIVE */
        @@media (max-width: 992px) {
            .left-panel {
                display: none;
            }

            .right-panel {
                width: 100%;
                background-color: #f8fafc;
                padding: 24px;
            }

            .mobile-logo {
                display: flex;
                align-items: center;
                gap: 10px;
                justify-content: center;
            }

            .login-content h2, .login-content p.subtitle {
                text-align: center;
            }
        }
    </style>
</head>
<body>

    <div class="container-custom">
        <div class="left-panel">
            <div class="logo-wrapper">
                <div class="logo-box">
                    <i class="fa fa-briefcase text-white"></i>
                </div>
                <h4 class="m-0 fw-bold">WorkFlow</h4>
            </div>
            <h1>Welcome back to your workspace</h1>
            <p>Manage projects, collaborate with teams, and grow your business — all in one place.</p>
        </div>

        <div class="right-panel">
            <div class="login-content">
                <!-- Mobile Logo -->
                <div class="mobile-logo">
                    <div class="logo-box">
                        <i class="fa fa-briefcase text-white"></i>
                    </div>
                    <h4 class="m-0 fw-bold" style="color:#0f172a">WorkFlow</h4>
                </div>

                <h2>Sign in to your account</h2>
                <p class="subtitle">Enter your credentials to access your dashboard</p>

                <form method="post">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-regular fa-envelope"></i></span>
                        <input asp-for="Input.Email" class="form-control border-start-0 shadow-none" placeholder="you@example.com" />
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label m-0">Password</label>
                        <a asp-page="./ForgotPassword" class="text-decoration-none" style="font-size: 13px; color: var(--emerald);">Forgot password?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa fa-lock"></i></span>
                        <input asp-for="Input.Password" type="password" class="form-control border-start-0 shadow-none" placeholder="••••••••" />
                    </div>

                    <div class="remember-row">
                        <input class="form-check-input me-2 shadow-none" type="checkbox" asp-for="Input.RememberMe">
                        <span>Remember me</span>
                    </div>

                    <button type="submit" class="btn btn-login w-100">Sign In <i class="fa fa-arrow-right ms-2"></i></button>

                    <div class="divider">Or continue with</div>

                    <div class="row g-2">
                        <div class="col-6">
                            <button type="button" class="btn btn-social w-100">
                                <i class="fa-brands fa-google"></i> Google
                            </button>
                        </div>
                        <div class="col-6">
                            <button type="button" class="btn btn-social w-100">
                                <i class="fa-brands fa-github"></i> GitHub
                            </button>
                        </div>
                    </div>

                    <p class="signup-text">
                        Don't have an account? <a asp-page="./Register">Sign up free</a>
                    </p>
                </form>
            </div>
        </div>
    </div>

</body>
</html>