@{
    ViewData["Title"] = "Home Page";
}
<div class="hero-wrapper d-flex align-items-center justify-content-center text-center">
    <div class="hero-overlay"></div>

    <div class="container hero-content position-relative">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h1 class="hero-title text-white fw-bold mb-4">
                    Your Gateway to Global Freelance Talent & Work
                </h1>
                <p class="hero-subtitle text-white-50 mb-5 mx-auto">
                    Connect with millions of top-rated freelancers or find exciting remote projects.
                    WORKFLOW is where productivity meets opportunity.
                </p>
                <a class="btn btn-emerald btn-lg rounded-pill px-5 py-3 fw-semibold shadow-lg"
                   asp-area="Identity" asp-page="/Account/Register">
                    Get Started Now <i class="fa fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>
</div>